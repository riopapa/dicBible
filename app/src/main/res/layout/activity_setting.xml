<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/setScrollView"
    xmlns:app="http://schemas.android.com/apk/res-auto">

<LinearLayout
    android:orientation="vertical"
    android:background="@color/SetBackColor"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 설정 header   -->
    <LinearLayout
        android:orientation="horizontal"
        android:background="@color/SetBackColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/goBack"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="◁"
            android:textColor="@color/SetForeColor"
            android:textSize="24sp"
            />
        <TextView
            android:layout_width="0dp"
            android:layout_weight="9"
            android:layout_margin="4sp"
            android:layout_gravity="center_horizontal"
            android:layout_height="wrap_content"
            android:text="설정"
            android:textColor="@color/SetForeColor"
            android:textSize="24sp"
            />
    </LinearLayout>

    <!--  dark mode, alwaysOn  -->
    <LinearLayout
        android:orientation="horizontal"
        android:background="@color/SetBackColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/dark_mode"
            style="@style/OnOffSwitch"
            android:layout_width="0dp"
            android:layout_weight="6"
            android:text="다크 모드"
            android:textColor="@color/SetForeColor"
            android:textSize="20sp"
            app:track="@drawable/switch_selector"
            />
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/always_on"
            style="@style/OnOffSwitch"
            android:layout_width="0dp"
            android:layout_weight="6"
            android:text="항시 켜있기"
            android:textColor="@color/SetForeColor"
            android:textSize="20sp"
            android:checked="true"
            app:track="@drawable/switch_selector"
            />
    </LinearLayout>

<!-- 성경 관련   -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bible"
        style="@style/SetStyle1"
        />

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >
        <TextView
            android:id="@+id/bibleSample"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/SetBackColor"
            android:padding="4sp"
            android:layout_marginStart="44sp"
            android:text="문단제목\n12 예수께서 대답하여 이르시되\n"
            />
    </LinearLayout>
    <!--    성경 글씨 크기 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="성경 글씨 크기"
        style="@style/SetStyle2"
        />
    <!--bible name-->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/txtName"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="@string/bibleName_size"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/bibleName_size_down"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/minus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
        <TextView
            android:id="@+id/bibleName_size"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/number"
            android:textStyle="bold"
            android:textSize="20sp" />
        <TextView
            android:id="@+id/bibleName_size_up"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/plus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>

    <!--bible body-->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/txtBibBody"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="@string/scripture_size"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/scripture_size_down"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/minus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
        <TextView
            android:id="@+id/scripture_size"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/number"
            android:textStyle="bold"
            android:textSize="20sp" />
        <TextView
            android:id="@+id/scripture_size_up"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/plus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>
    <!--bible keyword-->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/txtDic"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="@string/keyword_size"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/dic_size_down"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/minus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
        <TextView
            android:id="@+id/dic_size"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/number"
            android:textStyle="bold"
            android:textSize="20sp" />
        <TextView
            android:id="@+id/dic_size_up"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/plus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>
    <!--bible refer-->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/txtRef"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="@string/crossing_size"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/ref_size_down"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/minus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
        <TextView
            android:id="@+id/ref_size"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/number"
            android:textStyle="bold"
            android:textSize="20sp" />
        <TextView
            android:id="@+id/ref_size_up"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/plus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>
    <!--bible Read -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="성경 읽기"
        style="@style/SetStyle2"
        android:padding_Bottom="28sp"
        />
    <!--bible read speed-->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/speed_text"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="속도"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/speed_size_down"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/minus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
        <TextView
            android:id="@+id/speed_size"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/number"
            android:textStyle="bold"
            android:textSize="20sp" />
        <TextView
            android:id="@+id/speed_size_up"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/plus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>
    <!--bible read pitch-->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/pitch_text"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="높낮이"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/pitch_size_down"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/minus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
        <TextView
            android:id="@+id/pitch_size"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/number"
            android:textStyle="bold"
            android:textSize="20sp" />
        <TextView
            android:id="@+id/pitch_size_up"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/plus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>
    <!--search depth-->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/depth_text"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="검색 장수"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/depth_size_down"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/minus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
        <TextView
            android:id="@+id/depth_size"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/number"
            android:textStyle="bold"
            android:textSize="20sp" />
        <TextView
            android:id="@+id/depth_size_up"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/plus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>

    <!--    찬송 관련 설정 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="찬송"
        style="@style/SetStyle1"
        />
    <!--   찬송 레이아웃 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="찬송 레이 아웃"
        style="@style/SetStyle2"
        android:padding_Bottom="28sp"
        />
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioGroup
            android:id="@+id/hymnShowGrp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:orientation="horizontal"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/sheetYlyricY"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:textColor="@color/SetForeColor"
                android:text="@string/sheet_lyric"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/lyricYsheetY"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:textColor="@color/SetForeColor"
                android:text="@string/lyric_sheet"
                android:textSize="16sp" />
            <RadioButton
                android:id="@+id/sheet_only"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:layout_gravity="center"
                android:textColor="@color/SetForeColor"
                android:text="@string/sheet_only"
                android:textSize="16sp" />
            <RadioButton
                android:id="@+id/lyric_only"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:layout_gravity="center"
                android:textColor="@color/SetForeColor"
                android:text="@string/lyric_only"
                android:textSize="16sp" />
        </RadioGroup>
    </LinearLayout>

    <!--hymn text size-->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/txtHymnSize"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="가사 크기"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/hymn_size_down"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/minus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
        <TextView
            android:id="@+id/hymn_size"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/number"
            android:textStyle="bold"
            android:textSize="20sp" />
        <TextView
            android:id="@+id/hymn_size_up"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/plus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>
    <!--hymn song speed-->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/txtHymnSpeed"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="찬송 속도"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/hymn_speed_down"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/minus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
        <TextView
            android:id="@+id/hymn_sped"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/number"
            android:textStyle="bold"
            android:textSize="20sp" />
        <TextView
            android:id="@+id/hymn_speed_up"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/plus"
            android:textColor="#012345"
            android:textStyle="bold"
            android:textSize="24sp" />
    </LinearLayout>



    <!-- hymn accompany, play -->
    <LinearLayout
        android:gravity="center"
        android:style="@style/SetStyle2"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/accompany_choir"
            android:textSize="20sp"
            android:layout_width="0dp"
            android:layout_weight="4"
            android:gravity="center"
            android:textColor="@color/SetForeColor"
            android:layout_height="wrap_content"
            android:text="찬송가 타입"
            android:layout_gravity="center"
            />
        <RadioGroup
            android:id="@+id/hymnSpeakType"
            android:layout_width="0dp"
            android:layout_weight="8"
            android:orientation="horizontal"
            android:layout_height="wrap_content" >
            <RadioButton
                android:id="@+id/hymnChoir"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:textColor="@color/SetForeColor"
                android:text=" 합창"
                android:textSize="20sp" />
            <RadioButton
                android:id="@+id/hymnMusic"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:textColor="@color/SetForeColor"
                android:text=" 반주"
                android:textSize="20sp" />
        </RadioGroup>
    </LinearLayout>
            <!-- black background -->
            <LinearLayout
                android:gravity="center"
                android:padding="4dp"
                android:layout_marginTop="8dp"
                android:layout_margin="4dp"
                android:orientation="horizontal"
                android:background="@drawable/setting_border"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="6"
                    android:gravity="end|center_vertical"
                    android:layout_height="wrap_content"
                    android:text="@string/background_black"
                    android:layout_gravity="center"
                    android:textSize="20sp" />
                <CheckBox
                    android:layout_weight="2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:id="@+id/black_back"/>
            </LinearLayout>
        <!--bible bookmark-->

        <TextView
            android:padding="4dp"
            android:layout_margin="4dp"
            android:background="@drawable/setting_border"
            android:layout_width="match_parent"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="@string/bibleBookMark"
            android:layout_gravity="center"
            android:textSize="28sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/book_marks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layoutManager="GridLayoutManager"
            app:spanCount="2"
            >
        </androidx.recyclerview.widget.RecyclerView>
        <!--app info-->
        <TextView
            android:id="@+id/build_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:background="@color/appInfo"
            android:layout_gravity="center"
            android:text="@string/about"
            android:textSize="18sp" />
        <!--app info-->
        <TableLayout
            android:id="@+id/table"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
        </TableLayout>
    </LinearLayout>

</ScrollView>